{% style %}
  /* 基础消息容器 */
  .zora-message-item {
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  padding: 0.5rem 0;
  margin-bottom: 0.3rem;
  }

  .zora-message-left {
  flex-direction: row;
  }

  .zora-message-right {
  flex-direction: row-reverse;
  }

  /* 消息主体  */
  .zora-msg-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  max-width: 75%;
  }

  /* 用户名 */
  .zora-user {
  font-size: 0.75rem;
  color: var(--zora-text-secondary);
  margin-bottom: 0.1rem;
  font-weight: 400;
  }

  /* 消息布局 */
  .zora-message-left .zora-msg-box {
  align-items: flex-start;
  margin-left: 0.6rem;
  }

  .zora-message-right .zora-msg-box {
  align-items: flex-end;
  margin-right: 0.6rem;
  }

  /* 头像*/
  .zora-avatar {
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 50%;
  object-fit: cover;
  background: var(--zora-primary-light);
  }

  .zora-message-right .zora-avatar {
  background: var(--zora-primary);
  }

  .zora-message-left .zora-msg-content{
  flex-direction: row;
  }

  /* 消息内容容器 */
  .zora-msg-content {
  display: flex;
  flex-direction: row-reverse;
  align-items: flex-end;
  width: 100%;
  }

  /* 文本消息气泡 */
  .zora-msg {
  padding: 0.6rem 0.9rem;
  border-radius: 1rem;
  font-size: 0.9rem;
  line-height: 1.4;
  word-break: break-word;
  max-width: 100%;
  position: relative;
  }

  /* 左侧消息气泡（客服/卖家） */
  .zora-message-left .zora-msg {
  background: var(--zora-chat-bubble-agent);
  color: var(--zora-chat-bubble-text-agent);
  border: none;
  }

  /* 右侧消息气泡（用户） */
  .zora-message-right .zora-msg {
  background: var(--zora-chat-bubble-customer);
  color: var(--zora-chat-bubble-text-customer);
  }

  /* 消息状态指示器 */
  .zora-msg-read-state {
  margin: 0 0.3rem 0.2rem 0.3rem;
  font-size: 0.7rem;
  min-width: 2rem;
  color: var(--zora-text-secondary);
  }

  .zora-message-right .zora-msg-read-state {
  color: var(--zora-success-color);
  }

  .zora-message-right .msg-status-svg-box{
  font-size: 2rem;
  }

  /* 商品卡片 */
  .zora-message-product-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--zora-surface);
  border-radius: 0.8rem;
  padding: 0.9rem;
  max-width: 18rem;
  border: 1px solid var(--zora-border);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  /* 商品图片  */
  .zora-message-product-image-box {
  width: 98%;
  }

  .zora-message-product-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 0.6rem;
  }

  /* 商品信息区域  */
  .zora-message-product-info {
  padding-left: 0.9rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex: 1;
  }

  /* 商品标题 */
  .zora-message-product-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--zora-text-primary);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  }

  /* 商品描述 */
  .zora-message-product-desc {
  margin-top: 0.3rem;
  color: var(--zora-text-secondary);
  font-size: 0.8rem;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  }

  /* 标签区域  */
  .zora-message-product-tag-box {
  display: flex;
  flex-wrap: wrap;
  font-size: 0.6rem;
  margin-top: 0.3rem;
  column-gap: 0.5rem;
  row-gap: 0.5rem;
  max-height: 3rem;
  overflow-y: scroll;
  }

  .zora-message-product-tag-box::-webkit-scrollbar{
  display: none;
  width: 0;
  }

  .zora-message-product-tag {
  flex-shrink: 0;
  padding: 0.15rem 0.5rem;
  border-radius: 0.8rem;
  font-size: 0.65rem;
  font-weight: 600;
  background: var(--zora-badge-hot);
  color: var(--zora-surface);
  }

  .zora-message-product-tag.count {
  background: var(--zora-background);
  color: var(--zora-text-secondary);
  margin-left: 0.4rem;
  }

  /* 供应商信息 */
  .zora-message-product-vendor {
  margin-top: 0.4rem;
  font-size: 0.7rem;
  color: var(--zora-text-secondary);
  }

  /* 价格区域 */
  .zora-message-product-price-box {
  display: flex;
  flex-direction: column;
  margin-top: 0.4rem;
  }

  .zora-message-product-price {
  font-size: 1rem;
  font-weight: 600;
  color: var(--zora-primary);
  }

  .zora-message-product-price-line {
  font-size: 0.6rem;
  color: var(--zora-text-secondary);
  text-decoration: line-through;
  }

  /* 商品卡片的特殊标记  */
  .zora-message-product-flower-badge {
  position: absolute;
  top: -0.5rem;
  left: 0.5rem;
  background: var(--zora-surface);
  width: 1.2rem;
  height: 1.2rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 4px var(--zora-border);
  }

  .zora-message-product-flower-badge::after {
  content: "💐";
  font-size: 0.8rem;
  }

  /* 消息时间 */
  .zora-message-time {
  font-size: 0.65rem;
  color: var(--zora-text-secondary);
  margin-top: 0.1rem;
  }

  /* 发送中动画 */
  .loading-icon {
  width: 1.2rem;
  height: 1.2rem;
  opacity: 0.7;
  }

  .loading {
  animation: loading 1.5s infinite linear;
  }

  @keyframes loading {
  0% {
  transform: rotate(0deg);
  }
  100% {
  transform: rotate(360deg);
  }
  }

  /* 新消息动画 */
  @keyframes messageFadeIn {
  from {
  opacity: 0;
  transform: translateY(8px);
  }
  to {
  opacity: 1;
  transform: translateY(0);
  }
  }

  /* 滚动检测 */
  .is-not-intersecting {
  opacity: 0.3;
  }
{% endstyle %}
<zora-message-item-component class="zora-message-item-component">

</zora-message-item-component>
