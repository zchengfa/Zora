{% style %}
:root{
  /* 🌷 主色调 */
  --zora-primary: {{ block.settings.zora_primary }};
  --zora-primary-hover: {{ block.settings.zora_primary_hover }};
  --zora-primary-light: {{ block.settings.zora_primary_light }};
  --zora-primary-border: {{ block.settings.zora_primary_border }};

  /* 🍃 状态色 - 融入花卉主题 */
  --zora-error-color: {{ block.settings.zora_error_color }};
  --zora-success-color: {{ block.settings.zora_success_color }};
  --zora-info-color: {{ block.settings.zora_info_color }};
  --zora-warning-color: {{ block.settings.zora_warning_color }};

  /* 🌼 中性色 - 温柔大地色系 */
  --zora-text-primary: {{ block.settings.zora_text_primary }};
  --zora-text-secondary: {{ block.settings.zora_text_secondary }};
  --zora-background: {{ block.settings.zora_background }};
  --zora-surface: {{ block.settings.zora_surface }};
  --zora-border: {{ block.settings.zora_border }};

  /* 💬 聊天界面专用色 */
  --zora-chat-bubble-customer: {{ block.settings.zora_chat_bubble_customer }};
  --zora-chat-bubble-agent: {{ block.settings.zora_chat_bubble_agent }};
  --zora-chat-bubble-text-customer: {{ block.settings.zora_chat_bubble_text_customer }};
  --zora-chat-bubble-text-agent: {{ block.settings.zora_chat_bubble_text_agent }};

  /* 🌸 网站特定元素色 */
  --zora-header-bg: {{ block.settings.zora_header_bg }};
  --zora-search-border: {{ block.settings.zora_search_border }};
  --zora-button-bg: {{ block.settings.zora_button_bg }};
  --zora-button-text: {{ block.settings.zora_button_text }};
  --zora-badge-hot: {{ block.settings.zora_badge_hot }};
  --zora-badge-new: {{ block.settings.zora_badge_new }};
}
  div,input,button{
    box-sizing: border-box;
  }
  /* 隐藏滚动条 */
  .hidden-scroller::-webkit-scrollbar {
  display: none;
  }
  .zora-bubble-container.hidden{
    display:none;
  }
  /* 主容器定位 */
  .zora-main {
  position: fixed;
  width: fit-content;
  height: fit-content;
  left: 1.5rem;
  bottom: 1.5rem;
  z-index: 90;
  cursor: pointer;
  }

  /* 默认主按钮 */
  .zora-main-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: .5rem 1rem;
  width: fit-content;
  height: fit-content;
  border-radius: 20px;
  background: linear-gradient(135deg, #f8a5c2, #f78fb1);
  box-shadow: 0 4px 12px rgba(248, 165, 194, 0.3);
  transition: all 0.3s ease;
  border: 2px solid #ffffff;
  }

  .zora-main-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 20px rgba(248, 165, 194, 0.4);
  }

  .zora-main-btn:active {
  transform: scale(0.95);
  }

  /* 激活状态主按钮 */
  .zora-main-btn-active {
  display: flex;
  justify-content: center;
  align-items: center;
  width: fit-content;
  height: 3.5rem;
  border-radius: 20px;
  background: linear-gradient(135deg, #f8a5c2, #f78fb1);
  box-shadow: 0 4px 12px rgba(248, 165, 194, 0.3);
  border: 2px solid #ffffff;
  transition: all 0.3s ease;
  }

  /* 按钮图标 */
  .zora-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: var(--zora-surface);
  }

  /* 聊天图标 */
  .zora-chat-icon {
  color: var(--zora-surface);
  font-size: 1.8rem;
  }

  /* 关闭图标 */
  .btn-close {
  color: var(--zora-surface);
  width: 1.8rem;
  height: 1.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  }

  /* 按钮容器切换 */
  .zora-default-btn-box,
  .zora-active-btn-box {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.5rem;
  }

  .zora-active-btn-box.btn-box-hidden,
  .zora-default-btn-box.btn-box-hidden {
  display: none;
  }

  /* 呼吸动画 */
  @keyframes breathing {
  0% {
  box-shadow: 0 4px 12px rgba(248, 165, 194, 0.3);
  }
  50% {
  box-shadow: 0 4px 20px rgba(248, 165, 194, 0.5);
  }
  100% {
  box-shadow: 0 4px 12px rgba(248, 165, 194, 0.3);
  }
  }

  /* 新消息提示 */
  .zora-new-message-indicator {
  position: absolute;
  top: -4px;
  right: -4px;
  width: .8rem;
  height: .8rem;
  padding: .3rem;
  background: var(--zora-primary);
  border-radius: 50%;
  border: 2px solid var(--zora-surface);
  animation: pulse 2s infinite;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  color: #ffffff;
  font-weight: 600;
  min-width: 0.8rem;
  line-height: 1;
  }

  @keyframes pulse {
  0%, 100% {
  transform: scale(1);
  opacity: 1;
  }
  50% {
  transform: scale(1.2);
  opacity: 0.8;
  }
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
  .zora-main{
    left: 1.2rem;
  }
  .zora-default-btn-box,.zora-btn{
     font-size: 1rem;
  }
  .zora-main-btn,
  .zora-main-btn-active {
    width: fit-content;
  }
  .zora-main-btn{
    padding: .3rem .8rem;
  }

  .zora-chat-icon {
  font-size: 1.5rem;
  }

  .btn-close {
  font-size: 1.2rem;
  width: 1.5rem;
  height: 1.5rem;
  }
  }
{% endstyle %}

<div  id="zora-theme-app-extension zora-{{ block.id }}" class="zora-main" data-shop="{{ shop.domain }}" data-locale="{{ shop.locale }}">
  <zora-button class="zora-main-btn" data-target-class="zora-container" data-active-class="zora-container-active">
    <div class="zora-default-btn-box">
